# ============================================================
# NexoAI — Frontend Environment Variables
# Copiá como .env.local y completá los valores
# ============================================================

# URL del backend Django
VITE_API_BASE_URL=http://localhost:8000/api

# Meta App ID para el flow OAuth (login con Facebook)
VITE_META_APP_ID=XXXXXXXXXX

# App info
VITE_APP_NAME=NexoAI
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
